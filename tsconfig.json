{
	"compilerOptions": {
		"sourceMap": true,
		"declaration": true,
		"isolatedDeclarations": true,
		"isolatedModules": true,
		"allowUnusedLabels": false,
		"allowUnreachableCode": false,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"stableTypeOrdering": true,
		"noUncheckedIndexedAccess": true,
		"rootDir": "./src",
		"lib": [ "esnext", "dom" ],
		"module": "preserve"
	},
	"include": [ "./src" ]
}