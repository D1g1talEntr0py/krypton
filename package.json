{
  "name": "@d1g1tal/krypton",
  "author": "D1g1talEntr0py",
  "version": "2.0.0",
  "license": "MIT",
  "description": "Simple wrapper for the Web Crypto API",
  "homepage": "https://github.com/D1g1talEntr0py/krypton#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D1g1talEntr0py/krypton.git"
  },
  "bugs": {
    "url": "https://github.com/D1g1talEntr0py/krypton/issues"
  },
  "maintainers": [
    {
      "name": "D1g1talEntr0py",
      "email": "jason.dimeo@gmail.com"
    }
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "./dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsbuild",
    "build:watch": "tsbuild --watch",
    "type-check": "tsbuild --noEmit",
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@d1g1tal/tsbuild": "^1.7.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "4.1.3",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  },
  "browserslist": [
    "defaults",
    "not ios_saf < 15",
    "not op_mini all"
  ],
  "keywords": [
    "Crypto",
    "Encryption"
  ]
}
